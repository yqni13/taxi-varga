{
  "name": "taxi-varga",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "node ./set-env.dev.ts && ng serve --open",
    "start-local-ssl": "cross-env NODE_TLS_REJECT_UNAUTHORIZED=0 cmd /c \"node ./set-env.dev.ts && ng serve --ssl true --ssl-cert D:/Dokumente/GitHub/taxi-varga/local_ssl/localhost.crt --ssl-key D:/Dokumente/GitHub/taxi-varga/local_ssl/localhost.key --open\"",
    "start:stag": "node set-env.ts && ng serve --configuration staging",
    "start:prod": "node set-env.ts && ng serve --configuration production",
    "build": "ng build",
    "build:stag": "node set-env.ts && ng build --configuration staging",
    "build:prod": "node set-env.ts && ng build --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:taxi-varga": "node dist/taxi-varga/server/server.mjs",
    "lint": "ng lint"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^20.3.19",
    "@angular/common": "^20.3.19",
    "@angular/compiler": "^20.3.19",
    "@angular/core": "^20.3.19",
    "@angular/forms": "^20.3.19",
    "@angular/platform-browser": "^20.3.19",
    "@angular/platform-browser-dynamic": "^20.3.19",
    "@angular/platform-server": "^20.3.19",
    "@angular/router": "^20.3.19",
    "@angular/ssr": "^20.3.24",
    "@ngx-env/builder": "^19.0.4",
    "@ngx-translate/core": "^16.0.3",
    "brace-expansion": "^4.0.1",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "esbuild": "^0.25.5",
    "express": "^4.18.2",
    "http-proxy-middleware": "^3.0.5",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "underscore": "^1.13.7",
    "uuid": "^11.0.5",
    "vite": "^5.4.19",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular/build": "^20.3.24",
    "@angular/cli": "^20.3.24",
    "@angular/compiler-cli": "^20.3.19",
    "@types/crypto-js": "^4.2.2",
    "@types/express": "^4.17.17",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^18.19.68",
    "@types/underscore": "^1.13.0",
    "angular-eslint": "18.4.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.26.0",
    "jasmine-core": "~5.2.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.10.0",
    "webpack-dev-server": "^5.2.2"
  },
  "overrides": {
    "brace-expansion": "$brace-expansion",
    "esbuild": "$esbuild",
    "http-proxy-middleware": "$http-proxy-middleware",
    "webpack-dev-server": "$webpack-dev-server"
  }
}